PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/car_dealership
JWT_SECRET=your-secret-key-here
CORS_ORIGIN=http://localhost:5173


# Image uploads: leave unset to store files on local disk (public/uploads).
# Set this to push uploads to Cloudinary instead — required on Vercel, whose
# filesystem is read-only. Copy it from Cloudinary Dashboard -> API Keys.
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Demo accounts created on server start (the only way an admin ever exists)
# DEFAULT_ADMIN_EMAIL=admin@cardealership.com
# DEFAULT_ADMIN_PASSWORD=Admin@123
# DEFAULT_USER_EMAIL=user@cardealership.com
# DEFAULT_USER_PASSWORD=User@123
