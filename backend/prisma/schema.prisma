// Prisma schema for the Car Dealership Inventory System.
// Design reference: docs/database.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Authorization roles. Admins manage inventory; customers browse and purchase.
enum Role {
  CUSTOMER
  ADMIN
}

/// A registered user of the system (customer or admin).
model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchases Purchase[]

  @@map("users")
}

/// A vehicle listing in the dealership inventory.
model Vehicle {
  id        String   @id @default(uuid()) @db.Uuid
  make      String
  model     String
  category  String
  price     Decimal  @db.Decimal(12, 2)
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]

  // Search endpoint filters by make, model, category, and price range.
  @@index([make])
  @@index([model])
  @@index([category])
  @@index([price])
  @@map("vehicles")
}

/// Immutable audit record of a completed purchase.
/// purchasePrice snapshots the vehicle price at purchase time so history
/// stays accurate even if the listing price changes later.
model Purchase {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  vehicleId     String   @db.Uuid
  quantity      Int      @default(1)
  purchasePrice Decimal  @db.Decimal(12, 2)
  purchasedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Restrict prevents deleting a vehicle that has purchase history,
  // preserving the audit trail.
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([vehicleId])
  @@map("purchases")
}
